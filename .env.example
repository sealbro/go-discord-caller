# Required — the manager / owner bot token
DISCORD_OWNER_BOT_TOKEN=your-owner-bot-token-here

# Speaker bot pool — add as many as needed (gaps in numbering are supported)
DISCORD_SPEAKER_BOT_TOKEN_1=your-speaker-1-bot-token-here
DISCORD_SPEAKER_BOT_TOKEN_2=your-speaker-2-bot-token-here
# DISCORD_SPEAKER_BOT_TOKEN_3=...
